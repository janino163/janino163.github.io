---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = (await getCollection('projects'))
  .sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0))
  .slice(0, 2);
---

<BaseLayout title="Jose Nino">
  <section class="flex flex-col gap-6 sm:flex-row sm:items-start">
    <img
      src="/images/face.jpg"
      alt="Jose Nino"
      class="h-20 w-20 shrink-0 rounded-full object-cover ring-1 ring-zinc-200 dark:ring-zinc-800"
    />
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">Jose Nino</h1>
      <p class="mt-3 leading-7 text-zinc-700 dark:text-zinc-300">
        I'm a roboticist working on perception for autonomous vehicles — pedestrian
        forecasting and tracking, mostly. I did my Ph.D in Mechanical Engineering at
        Cornell University, advised by{' '}
        <a href="https://campbell.mae.cornell.edu/" class="text-accent-600 underline decoration-accent-500/40 underline-offset-2 hover:decoration-accent-500 dark:text-accent-400">Mark Campbell</a>,
        and my B.S. in Mechanical Engineering at Purdue University.
      </p>
      <p class="mt-3 leading-7 text-zinc-700 dark:text-zinc-300">
        This site is where I write about what I'm building and learning, and share
        the projects I work on outside of research.
      </p>
      <div class="mt-4 flex flex-wrap gap-4 text-sm font-medium">
        <a href="mailto:jan268@cornell.edu" class="text-accent-600 hover:underline dark:text-accent-400">Email</a>
        <a href="https://github.com/janino163" class="text-accent-600 hover:underline dark:text-accent-400">GitHub</a>
        <a href="https://twitter.com/josenino22" class="text-accent-600 hover:underline dark:text-accent-400">Twitter</a>
        <a href="/cv/" class="text-accent-600 hover:underline dark:text-accent-400">CV</a>
      </div>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="mt-16">
      <div class="flex items-baseline justify-between">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Recent posts</h2>
        <a href="/blog/" class="text-sm text-accent-600 hover:underline dark:text-accent-400">View all</a>
      </div>
      <div class="mt-4">
        {posts.map((post) => (
          <PostCard
            href={`/blog/${post.id}/`}
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
          />
        ))}
      </div>
    </section>
  )}

  {projects.length > 0 && (
    <section class="mt-16">
      <div class="flex items-baseline justify-between">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Featured projects</h2>
        <a href="/projects/" class="text-sm text-accent-600 hover:underline dark:text-accent-400">View all</a>
      </div>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        {projects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            repoUrl={project.data.repoUrl}
            liveUrl={project.data.liveUrl}
            stack={project.data.stack}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
