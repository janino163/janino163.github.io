---
interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  tags: string[];
}

const { href, title, description, date, tags } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<a href={href} class="group block border-b border-zinc-200 py-6 first:pt-0 dark:border-zinc-800">
  <time datetime={date.toISOString()} class="font-mono text-xs text-zinc-500 dark:text-zinc-400">
    {formattedDate}
  </time>
  <h2 class="mt-1 text-lg font-semibold text-zinc-900 group-hover:text-accent-600 dark:text-zinc-100 dark:group-hover:text-accent-400">
    {title}
  </h2>
  <p class="mt-1 text-sm leading-6 text-zinc-600 dark:text-zinc-400">{description}</p>
  {tags.length > 0 && (
    <ul class="mt-3 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <li class="rounded-full bg-accent-50 px-2.5 py-0.5 font-mono text-xs text-accent-600 dark:bg-accent-600/10 dark:text-accent-400">
          {tag}
        </li>
      ))}
    </ul>
  )}
</a>
